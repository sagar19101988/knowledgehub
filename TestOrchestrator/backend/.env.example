# Copy this to backend/.env and fill in your values

# Authentication
JWT_SECRET=your-strong-random-secret-here

# Encryption (MUST be exactly 32 hex characters - generate with: node -e "require('crypto').randomBytes(32).toString('hex').slice(0,32)" | Write-Host)
ENCRYPTION_KEY=your-32-char-hex-key-here

# Postgres (from Neon, Supabase, or Vercel Postgres)
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require

# LLM Provider (Groq key starts with gsk_, OpenAI with sk-)
OPENAI_API_KEY=your-groq-or-openai-key-here

# Local dev only
PORT=3001
